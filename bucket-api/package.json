{
  "name": "@datacentricdesign/bucket-api",
  "version": "0.1.0",
  "description": "A bucket of data, in the cloud.",
  "main": "index.js",
  "scripts": {
    "start": "ts-node-dev --respawn --transpile-only  ./src/index.ts",
    "build": "tsc",
    "typeorm:cli": "node ./node_modules/typeorm/cli -f ./dist/config/ormMigrationWrap.js",
    "migration:run": "npm run typeorm:cli migration:run",
    "test": "mocha -r ts-node/register --file src/test/setup.ts src/**/*.test.ts --timeout 10000",
    "coverage": "nyc npm run test",
    "prod": "npm run doc && ts-node ./src/index.ts",
    "doc": "apidoc -i src/ -o dist/public/docs/",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.ts'",
    "prepare": "cd .. && husky install bucket-api/.husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datacentricdesign/bucket.git"
  },
  "author": "Data-Centric Design Lab <lab@datacentricdesign.org>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/datacentricdesign/bucket/issues"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix"
    ]
  },
  "homepage": "https://github.com/datacentricdesign/bucket#readme",
  "dependencies": {
    "@datacentricdesign/types": "0.0.6",
    "@influxdata/influxdb-client": "^1.13.0",
    "@influxdata/influxdb-client-apis": "^1.13.0",
    "aedes": "0.46.0",
    "apidoc": "0.24.0",
    "body-parser": "^1.19.0",
    "btoa": "^1.2.1",
    "class-validator": "0.12.2",
    "cookie-parser": "1.4.5",
    "cors": "2.8.5",
    "dotenv": "^8.2.0",
    "envalid": "6.0.2",
    "express": "4.17.1",
    "express-session": "1.17.1",
    "helmet": "3.23.3",
    "influx": "5.6.2",
    "jsonwebtoken": "8.5.1",
    "jwk-to-pem": "2.0.4",
    "moment": "^2.27.0",
    "mqtt": "4.1.0",
    "multiparty": "^4.2.2",
    "node-fetch": "^2.6.1",
    "node-jose": "^2.0.0",
    "passport": "0.4.1",
    "passport-oauth2": "1.5.0",
    "passport-oauth2-refresh": "2.0.0",
    "pem-jwk": "2.0.0",
    "pg": "8.6.0",
    "reflect-metadata": "^0.1.13",
    "simple-oauth2": "4.1.0",
    "tslog": "3.2.0",
    "typeorm": "0.2.32",
    "url": "0.11.0",
    "uuid": "8.3.0"
  },
  "devDependencies": {
    "@types/body-parser": "1.19.0",
    "@types/chai": "^4.2.17",
    "@types/cookie-parser": "1.4.2",
    "@types/cors": "2.8.6",
    "@types/express": "4.17.7",
    "@types/express-session": "1.17.0",
    "@types/helmet": "0.0.47",
    "@types/jsonwebtoken": "8.5.0",
    "@types/jwk-to-pem": "2.0.0",
    "@types/mocha": "^8.2.2",
    "@types/multiparty": "0.0.32",
    "@types/node": "14.0.27",
    "@types/node-fetch": "2.5.7",
    "@types/node-jose": "^1.1.5",
    "@types/passport": "1.0.4",
    "@types/passport-oauth2-refresh": "1.1.1",
    "@types/pem-jwk": "1.5.0",
    "@types/simple-oauth2": "4.1.0",
    "@types/sinon": "^10.0.0",
    "@types/uuid": "8.0.0",
    "@typescript-eslint/eslint-plugin": "^4.25.0",
    "@typescript-eslint/parser": "^4.22.0",
    "chai": "^4.3.4",
    "eslint": "^7.27.0",
    "eslint-config-airbnb-typescript": "^12.3.1",
    "eslint-config-prettier": "8.3.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.23.3",
    "eslint-plugin-prettier": "3.4.0",
    "husky": "6.0.0",
    "lint-staged": "^10.5.4",
    "mocha": "^8.3.2",
    "node-mocks-http": "^1.10.1",
    "nyc": "^15.1.0",
    "prettier": "2.2.1",
    "sinon": "^10.0.0",
    "ts-node": "8.10.2",
    "ts-node-dev": "1.0.0-pre.56",
    "typescript": "3.9.7"
  }
}
